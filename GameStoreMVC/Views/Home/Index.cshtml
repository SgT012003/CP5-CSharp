@model IEnumerable<GameStoreMVC.Models.Game>

@{
    ViewData["Title"] = " Games | Home";
}

<div class="p-5 mb-4 bg-dark rounded-3 jumbotron-hero"
     style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)),
            url('/img/fundo.jpg') no-repeat center/cover;">

    <div class="container-fluid py-5 text-white">
        <h1 class="display-5 fw-bold">Domine o Jogo</h1>
        <p class="col-md-8 fs-4">Os lançamentos mais esperados e as melhores ofertas em um só lugar. Upgrade no seu setup começa aqui.</p>
        <button class="btn btn-neon btn-lg" type="button">Ver Ofertas</button>
    </div>
</div>

<div class="container mb-5">
    <div class="d-flex justify-content-center gap-3 flex-wrap">
        <span class="badge rounded-pill bg-secondary p-2 px-3">RPG</span>
        <span class="badge rounded-pill bg-secondary p-2 px-3">Ação</span>
        <span class="badge rounded-pill bg-secondary p-2 px-3">Corrida</span>
        <span class="badge rounded-pill bg-secondary p-2 px-3">Aventura</span>
    </div>
</div>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Em Destaque</h2>
        @if (User.Identity != null && User.IsInRole("Admin"))
        {
            <a asp-controller="Game" asp-action="Create" class="btn btn-sm fw-bold" style="background-color: #00ff88; color: #000;">
                <i class="bi bi-plus-circle"></i> Novo Jogo
            </a>
        }
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var game in Model)
            {
                <div class="col">
                    <div class="card h-100 bg-dark text-white shadow-sm border-0" style="border-bottom: 3px solid #00ff88!important; transition: transform 0.3s ease;">
                        @if (!string.IsNullOrEmpty(game.UrlImagem))
                        {
                            <img src="@game.UrlImagem" class="card-img-top" alt="@game.Titulo" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top d-flex align-items-center justify-content-center bg-secondary" style="height: 200px;">
                                <i class="bi bi-controller fs-1 text-light"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@game.Titulo</h5>
                            <p class="card-text text-muted small text-truncate">@game.Descricao</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="fs-4 fw-bold" style="color: #00ff88;">@game.Preco.ToString("C")</span>
                                <button class="btn btn-sm btn-outline-light"><i class="bi bi-cart-plus"></i> Comprar</button>
                            </div>
                            @if (User.Identity != null && User.IsInRole("Admin"))
                            {
                                <div class="mt-3 pt-3 border-top border-secondary d-flex justify-content-between">
                                    <a asp-controller="Game" asp-action="Edit" asp-route-id="@game.Id" class="btn btn-sm btn-outline-warning w-50 me-1">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <a asp-controller="Game" asp-action="Delete" asp-route-id="@game.Id" class="btn btn-sm btn-outline-danger w-50 ms-1">
                                        <i class="bi bi-trash"></i> Excluir
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-dark text-center" role="alert">
                    Nenhum jogo cadastrado ainda.
                </div>
            </div>
        }
    </div>
</div>