@model GameStoreMVC.Models.CadastroViewModel

@{
    ViewData["Title"] = "Cadastrar";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-6">
        <div class="card shadow-lg bg-dark text-white" style="border: 1px solid #00ff88; border-radius: 15px;">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-person-plus-fill" style="font-size: 3rem; color: #00ff88;"></i>
                    <h3 class="mt-2 fw-bold">Criar Nova Conta</h3>
                    <p class="text-muted small">Junte-se a milhares de gamers</p>
                </div>

                <form asp-action="Salvar" method="post">
                    <div class="mb-3">
                        <label asp-for="Nome" class="form-label text-muted">Nome Completo</label>
                        <input asp-for="Nome" class="form-control bg-dark text-white border-secondary" placeholder="Seu nome" />
                        <span asp-validation-for="Nome" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-muted">Email</label>
                        <input asp-for="Email" class="form-control bg-dark text-white border-secondary" placeholder="seu@email.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Senha" class="form-label text-muted">Senha</label>
                            <input asp-for="Senha" class="form-control bg-dark text-white border-secondary" placeholder="••••••••" />
                            <span asp-validation-for="Senha" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label asp-for="ConfirmacaoSenha" class="form-label text-muted">Confirmar Senha</label>
                            <input asp-for="ConfirmacaoSenha" class="form-control bg-dark text-white border-secondary" placeholder="••••••••" />
                            <span asp-validation-for="ConfirmacaoSenha" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn fw-bold py-2" style="background-color: #00ff88; color: #000;">Cadastrar</button>
                        <a asp-action="Index" class="btn btn-outline-secondary py-2 mt-2">Voltar para Login</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
