@model GameStoreMVC.Models.Game

@{
    ViewData["Title"] = "Editar Jogo";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-8">
        <div class="card shadow-lg bg-dark text-white" style="border: 1px solid #00ff88; border-radius: 15px;">
            <div class="card-header border-bottom border-secondary p-4">
                <h3 class="mb-0 fw-bold"><i class="bi bi-pencil-square text-warning"></i> Editar Jogo</h3>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="mb-3">
                        <label asp-for="Titulo" class="form-label text-muted">Título</label>
                        <input asp-for="Titulo" class="form-control bg-dark text-white border-secondary" required />
                        <span asp-validation-for="Titulo" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descricao" class="form-label text-muted">Descrição</label>
                        <textarea asp-for="Descricao" class="form-control bg-dark text-white border-secondary" rows="3"></textarea>
                        <span asp-validation-for="Descricao" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Preco" class="form-label text-muted">Preço (R$)</label>
                            <input asp-for="Preco" type="number" step="0.01" class="form-control bg-dark text-white border-secondary" required />
                            <span asp-validation-for="Preco" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label asp-for="UrlImagem" class="form-label text-muted">URL da Imagem</label>
                            <input asp-for="UrlImagem" class="form-control bg-dark text-white border-secondary" placeholder="https://..." />
                            <span asp-validation-for="UrlImagem" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn fw-bold px-4" style="background-color: #00ff88; color: #000;">Atualizar</button>
                        <a asp-action="Index" class="btn btn-outline-light px-4">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
