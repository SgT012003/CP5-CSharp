<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GameStoreMVC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GameStoreMVC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3 py-3" style="border-bottom-color: #00ff88!important; border-bottom-width: 2px!important;">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index" style="color: #00ff88; letter-spacing: 1px;">
                    <i class="bi bi-controller"></i> GAME<span class="text-white">STORE</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Início</a>
                        </li>
                        @if (User.Identity != null && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light fw-semibold" asp-area="" asp-controller="Game" asp-action="Index">Gerenciar Jogos</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="text-light me-3">Olá, <strong style="color: #00ff88;">@User.Identity.Name</strong>!</span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm mt-1" asp-area="" asp-controller="Login" asp-action="Sair">Sair</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-outline-light btn-sm mt-1" asp-area="" asp-controller="Login" asp-action="Index">Entrar</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-success btn-sm mt-1 fw-bold" asp-area="" asp-controller="Login" asp-action="Cadastrar" style="background-color: #00ff88; color: #000; border: none;">Cadastrar-se</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top-neon bg-dark-card pt-5 pb-3">
        <div class="container text-white">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h4 class="fw-bold mb-3" style="color: #00ff88;">GAME<span class="text-white">STORE</span></h4>
                    <p class="text-muted small">Sua arena gamer definitiva. Os melhores títulos, as ofertas mais quentes e a maior comunidade de jogadores você encontra aqui.</p>
                    <div class="d-flex gap-3 mt-3">
                        <a href="#" class="text-white fs-5"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-white fs-5"><i class="bi bi-discord"></i></a>
                        <a href="#" class="text-white fs-5"><i class="bi bi-twitch"></i></a>
                    </div>
                </div>

                <div class="col-6 col-md-2 mb-4">
                    <h6 class="fw-bold text-uppercase mb-3">Loja</h6>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small hover-neon">Todos os Games</a></li>
                        <li><a href="#" class="text-muted text-decoration-none small hover-neon">Lançamentos</a></li>
                        <li><a href="#" class="text-muted text-decoration-none small hover-neon">Promoções</a></li>
                    </ul>
                </div>

                <div class="col-6 col-md-2 mb-4">
                    <h6 class="fw-bold text-uppercase mb-3">Suporte</h6>
                    <ul class="list-unstyled">
                        <li><a asp-action="Privacy" class="text-muted text-decoration-none small hover-neon">Privacidade</a></li>
                        <li><a href="#" class="text-muted text-decoration-none small hover-neon">Termos de Uso</a></li>
                        <li><a href="#" class="text-muted text-decoration-none small hover-neon">Fale Conosco</a></li>
                    </ul>
                </div>

                <div class="col-md-4 mb-4">
                    <h6 class="fw-bold text-uppercase mb-3">Fique por dentro</h6>
                    <div class="input-group input-group-sm mb-3">
                        <input type="text" class="form-control bg-dark border-secondary text-white" placeholder="Seu melhor e-mail">
                        <button class="btn btn-success btn-sm fw-bold" type="button">OK</button>
                    </div>
                    <p class="text-muted" style="font-size: 0.75rem;">Receba cupons de desconto exclusivos!</p>
                </div>
            </div>

            <hr class="bg-secondary opacity-25">

            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center mt-3">
                <p class="text-muted small mb-0">&copy; 2026 - GameStoreMVC. Todos os direitos reservados.</p>
                <div class="payment-icons">
                    <i class="bi bi-credit-card-2-back text-muted fs-4 ms-2" title="Cartão"></i>
                    <i class="bi bi-qr-code text-muted fs-4 ms-2" title="Pix"></i>
                    <i class="bi bi-paypal text-muted fs-4 ms-2" title="PayPal"></i>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
